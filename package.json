{
    "authors": [
        "Paul Gilchrist"
    ],
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "description": "Dungeons and Dragons Character Sheet",
    "homepage": "https://paulgilchrist.github.io/dnd-char-sheet",
    "license": "MIT",
    "name": "dnd-char-sheet",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/PaulGilchrist/dnd-char-sheet.git"
    },
    "scripts": {
        "deploy": "gh-pages -d dist",
        "dev": "concurrently \"npm run api\" \"npm run dev:react\"",
        "dev:react": "vite --host",
        "api": "node server.js",
        "build": "vite build",
        "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
        "predeploy": "npm run build",
        "preview": "vite preview --host",
        "start": "concurrently \"caffeinate -d -i\" \"npm run build && npm run preview\" \"npm run api\""
    },
    "type": "module",
    "version": "0.0.0",
    "dependencies": {
        "concurrently": "^9.2.1",
        "express": "^5.2.1",
        "file-saver": "^2.0.5",
        "guid": "^0.0.12",
        "lodash": "^4.17.21",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-router-dom": "^7.14.0"
    },
    "devDependencies": {
        "@babel/eslint-parser": "^7.28.6",
        "@babel/preset-react": "^7.28.5",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^8.57.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^4.6.2",
        "eslint-plugin-react-refresh": "^0.4.26",
        "gh-pages": "^6.1.1",
        "globals": "^17.4.0",
        "vite": "^8.0.6"
    }
}
