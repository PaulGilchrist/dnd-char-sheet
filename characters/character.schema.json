{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Character Schema",
    "description": "Schema for D&D 5e character data",
    "type": "object",
    "required": [
        "name",
        "level",
        "alignment",
        "race",
        "class",
        "abilities",
        "inventory",
        "skillProficiencies",
        "rules"
    ],
    "properties": {
        "name": {
            "type": "string",
            "description": "The character's name"
        },
        "level": {
            "type": "integer",
            "maximum": 20,
            "minimum": 1,
            "description": "The character's current level"
        },
        "alignment": {
            "type": "string",
            "description": "The character's moral and ethical alignment (e.g., 'Neutral Good')"
        },
        "background": {
            "type": "string",
            "description": "The character's background (e.g., 'Acolyte', 'Guide', 'Soldier')"
        },
        "race": {
            "type": "object",
            "description": "The character's racial information",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The character's race name (e.g., 'Human', 'Elf', 'Tiefling', 'Half-Orc')"
                },
                "subrace": {
                    "type": "object",
                    "description": "Optional racial subrace information",
                    "required": [
                        "name"
                    ],
                    "properties": {
                        "name": {
                            "type": "string",
                            "description": "The character's subrace name (e.g., 'Wood Elf', 'Human', 'Variant Human', 'High Elf')"
                        }
                    }
                }
            }
        },
        "class": {
            "type": "object",
            "description": "The character's class information",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The character's class name (e.g., 'Fighter', 'Wizard', 'Cleric', 'Rogue', 'Bard', 'Druid', 'Barbarian')"
                },
                "subclass": {
                    "type": "object",
                    "description": "Optional subclass specialization information",
                    "properties": {
                        "name": {
                            "type": "string",
                            "description": "The subclass name (e.g., 'Battle Master', 'Lore', 'Life', 'Thief', 'Evocation', 'Berserker', 'Tempest', 'Divination', 'Moon', 'Beast Master')"
                        },
                        "type": {
                            "type": "string",
                            "description": "Optional subclass type or variant (e.g., 'Forest' for Druid, 'Coast' for Moon Druid)"
                        }
                    }
                },
                "fightingStyles": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Optional array of fighting styles (e.g., 'Archery')"
                },
                "expertise": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Optional array of skills with expertise bonus"
                },
                "favoredEnemies": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Optional array of favored enemy types (Ranger class)"
                },
                "favoredTerrain": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Optional array of favored terrain types (Ranger class)"
                }
            }
        },
        "abilities": {
            "type": "array",
            "description": "Array of ability scores",
            "items": {
                "type": "object",
                "required": [
                    "name",
                    "baseScore"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Ability name (Strength, Dexterity, Constitution, Intelligence, Wisdom, Charisma)"
                    },
                    "baseScore": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 30,
                        "description": "The base score for this ability before modifiers"
                    },
                    "abilityImprovements": {
                        "type": "integer",
                        "description": "Number of ability score improvements applied"
                    },
                    "miscBonus": {
                        "type": "integer",
                        "description": "Miscellaneous bonus to this ability score from various sources"
                    }
                }
            }
        },
        "skillProficiencies": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Array of skills the character is proficient in"
        },
        "inventory": {
            "type": "object",
            "description": "Character's inventory and equipment",
            "required": [
                "backpack",
                "equipped",
                "gold"
            ],
            "properties": {
                "backpack": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Array of items in the character's backpack"
                },
                "equipped": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Array of currently equipped items"
                },
                "gold": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Amount of gold pieces the character possesses"
                },
                "magicItems": {
                    "type": "array",
                    "description": "Optional array of magic items with detailed properties",
                    "items": {
                        "type": "object",
                        "required": [
                            "name"
                        ],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Name of the magic item"
                            },
                            "description": {
                                "type": "string",
                                "description": "Detailed description of the item's properties and effects"
                            },
                            "rarity": {
                                "type": "string",
                                "description": "Item rarity (common, uncommon, rare, very rare, legendary)"
                            },
                            "requiresAttunement": {
                                "type": "boolean",
                                "description": "Whether the item requires attunement to use"
                            },
                            "type": {
                                "type": "string",
                                "description": "Item type (e.g., 'Weapon (mace)', 'Armor (Breastplate)', 'Wondrous item')"
                            },
                            "bonus": {
                                "type": "string",
                                "description": "Bonus value for items that provide numerical bonuses (e.g., '+1')"
                            },
                            "quantity": {
                                "type": "integer",
                                "minimum": 1,
                                "description": "Quantity of items when multiple are present"
                            }
                        }
                    }
                }
            }
        },
        "languages": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Array of languages the character can speak and read"
        },
        "spells": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Array of spells the character knows or has prepared"
        },
        "resistances": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Array of damage types the character has resistance to (e.g., 'Fire', 'Cold')"
        },
        "immunities": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Array of damage types the character has immunity to (e.g., 'Fire', 'Cold')"
        },
        "feats": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Optional array of feats the character has selected (e.g., 'Resilient', 'War Caster', 'Moderately Armored')"
        },
        "specialActions": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Optional array of special actions the character can perform.  This can be used for custom magic items or other abilities awarded by the Dungeon Master"
        },
        "rules": {
            "type": "string",
            "description": "Rule system version used (e.g., '5e', '2024')"
        }
    }
}